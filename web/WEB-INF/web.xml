<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Blood Bank Management System</display-name>

    <!-- Explicitly Map JSP Servlet (Forces JSP processing) -->
    <servlet>
        <servlet-name>jsp</servlet-name>
        <servlet-class>org.apache.jasper.servlet.JspServlet</servlet-class>
        <load-on-startup>3</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>jsp</servlet-name>
        <url-pattern>*.jsp</url-pattern>
        <url-pattern>*.jspx</url-pattern>
    </servlet-mapping>


    <!-- ================= NEWSLETTER SUBSCRIBE ================= -->
    <servlet>
        <servlet-name>SubscribeServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.SubscribeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubscribeServlet</servlet-name>
        <url-pattern>/api/subscribe</url-pattern>
    </servlet-mapping>

    <!-- ================= EMERGENCY NOTIFICATIONS ================= -->
    <servlet>
        <servlet-name>EmergencyNotificationServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.EmergencyNotificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmergencyNotificationServlet</servlet-name>
        <url-pattern>/api/emergency-broadcast</url-pattern>
    </servlet-mapping>

    <!-- ================= AI ASSISTANCE ================= -->
    <servlet>
        <servlet-name>AIDispatchHelperServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.AIDispatchHelperServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AIDispatchHelperServlet</servlet-name>
        <url-pattern>/api/ai-dispatch-helper</url-pattern>
    </servlet-mapping>

    <!-- ================= INTELLIGENCE BRIEFING ================= -->
    <servlet>
        <servlet-name>IntelligenceBriefingServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.IntelligenceBriefingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>IntelligenceBriefingServlet</servlet-name>
        <url-pattern>/api/intelligence-briefing</url-pattern>
    </servlet-mapping>

    <!-- ================= WELCOME ================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>


</web-app>
